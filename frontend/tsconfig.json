{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./src/dist",
    "module": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": [],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "src/dist"]
}
